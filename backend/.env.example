# =============================================================
# ContentRewards - Environment Variables Template
# =============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# =============================================================

# -----------------------------------------------------------
# REQUIRED: AI Analysis (at least one must be filled)
# -----------------------------------------------------------

# Option 1: Gemini (Google AI Studio - free tier available)
# Get key at: https://aistudio.google.com/
GEMINI_API_KEY=

# Option 2: OpenRouter (free models available - deepseek, qwen, etc.)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# Option 3: SiliconFlow (Chinese free AI - Qwen/DeepSeek, very generous free tier)
# Get key at: https://cloud.siliconflow.cn/
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3

# AI provider selection: 'gemini', 'openrouter', or 'siliconflow'
# Leave empty to auto-detect based on which API key is filled above
AI_PROVIDER=

# -----------------------------------------------------------
# OPTIONAL: YouTube Auto-Upload feature
# -----------------------------------------------------------
# Only needed if you want to upload clips directly to YouTube.
# Without this, the app still works for clip generation & thumbnails.
#
# Setup steps:
# 1. Go to https://console.cloud.google.com/
# 2. Create a project -> Enable "YouTube Data API v3"
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add http://localhost:5000/api/auth/youtube/callback as Redirect URI
# 5. Copy Client ID and Client Secret below

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:5000/api/auth/youtube/callback
